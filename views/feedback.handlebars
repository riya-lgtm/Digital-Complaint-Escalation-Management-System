<div class="form-container" style="max-width: 600px;">
    <h2 class="page-title">Submit Feedback</h2>
    
    <form method="post" action="/submitFeedback">
        <div class="form-group mb-3">
            <label>Name</label>
            <input class="form-control" type="text" name="name" placeholder="Full Name" >
        </div>
        <div class="form-group mb-3">
            <label>Email</label>
            <input class="form-control" type="email" name="email" placeholder="Email Address">
        </div>
        <div class="form-group mb-3">
            <label>Feedback Message</label>
            <textarea class="form-control" name="message" cols="30" rows="5" placeholder="Share your thoughts with us..." style="resize: none;"></textarea>
        </div>
        
        <button class="btn btn-success mt-3 mb-4" style="padding: 1rem;" type="submit">Submit Feedback</button>
        
        <div class="text-center pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
            <span class="text-muted">Want to go back?</span> <a class="btn btn-warning btn-sm ml-2" href="/">Home</a>
        </div>
    </form>
</div>
