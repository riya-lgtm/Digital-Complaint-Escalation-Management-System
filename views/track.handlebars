<div class="form-container">
    <h3 class="mb-4 text-center" style="color: #e2e8f0; font-weight: 600;"><i class="fas fa-search mr-2"></i>Track Your Complaint</h3>
    <form method="post" action="/track">
        <div class="form-group mb-4">
            <label style="color: #94a3b8;">Complaint ID</label>
            <input class="form-control" type="text" name="complaintID" placeholder="Enter your 24-character Object ID..." required>
        </div>
        <div class="form-group mb-0 mt-4">
            <button type="submit" class="btn btn-primary btn-block p-3 font-weight-bold" style="font-size: 1.1rem;">Track Status</button>
        </div>
    </form>
</div>

{{#if tracked}}
<div class="form-container mt-4 pb-4" style="background-color: rgba(30, 41, 59, 0.5);">
    <h4 style="color: #60a5fa;" class="mb-4"><i class="fas fa-file-invoice mr-2"></i>Complaint Details</h4>
    <div class="row">
        <div class="col-md-6 mb-3">
            <span style="color: #94a3b8; font-size: 0.9rem;">Status</span><br>
            {{#if mapping}}
                <span class="badge" style="background-color: rgba(34, 197, 94, 0.2); color: #4ade80; border: 1px solid #22c55e; padding: 0.5rem 1rem; font-size: 0.9rem; margin-top: 5px;">Assigned / In Progress</span>
            {{else}}
                <span class="badge" style="background-color: rgba(249, 115, 22, 0.2); color: #fb923c; border: 1px solid #f97316; padding: 0.5rem 1rem; font-size: 0.9rem; margin-top: 5px;">Pending Assignment</span>
            {{/if}}
        </div>
        {{#if mapping}}
        <div class="col-md-6 mb-3">
            <span style="color: #94a3b8; font-size: 0.9rem;">Assigned Engineer</span><br>
            <span style="color: #e2e8f0; font-size: 1.1rem; padding-top: 5px; display: inline-block;"><strong>{{mapping.engineerName}}</strong></span>
        </div>
        {{/if}}
    </div>
    <hr style="border-color: #334155; margin: 1.5rem 0;">
    <div class="mb-3">
        <span style="color: #94a3b8; font-size: 0.9rem;">Description provided:</span>
        <div class="p-3 mt-2" style="background-color: rgba(0,0,0,0.2); border-radius: 8px; border: 1px solid #334155; color: #e2e8f0; line-height: 1.5;">
            {{complaint.desc}}
        </div>
    </div>
</div>
{{/if}}
